# Project Chimera Environment Variables
# Copy this file to .env and fill in your actual values

# OpenAI API Key (optional if using OpenRouter)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic API Key (optional if using OpenRouter)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Gemini API Key
GOOGLE_API_KEY="your_gemini_key_here"

# OpenRouter API Key (for free models)
OPENROUTER_API_KEY="your_open_router_key_here"

# OpenRouter Site Info (optional)
OPENROUTER_SITE_URL=https://project-chimera.research
OPENROUTER_SITE_NAME=Project Chimera Research

# Simulation settings
CHIMERA_LOG_LEVEL=DEBUG
CHIMERA_DATA_DIR=./data
CHIMERA_RESULTS_DIR=./results

# Database settings
DATABASE_URL=postgresql://developer:dev123@localhost:5432/chimera_project
REDIS_URL=redis://localhost:6379
